# Apache configuration for SPA routing
# Place in your public_html or www root directory

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Explicitly allow existing files to be served
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
  
  # Explicitly allow existing directories to be accessed
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Ensure specific file types are served correctly
  RewriteCond %{REQUEST_FILENAME} !\.js$
  RewriteCond %{REQUEST_FILENAME} !\.css$
  RewriteCond %{REQUEST_FILENAME} !\.svg$
  RewriteCond %{REQUEST_FILENAME} !\.webmanifest$
  RewriteCond %{REQUEST_FILENAME} !\.woff2?$
  RewriteCond %{REQUEST_FILENAME} !\.png$
  RewriteCond %{REQUEST_FILENAME} !\.jpg$
  RewriteCond %{REQUEST_FILENAME} !\.jpeg$
  RewriteCond %{REQUEST_FILENAME} !\.gif$
  RewriteCond %{REQUEST_FILENAME} !\.ico$
  
  # Fallback all other requests to index.html
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Proper MIME types
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
  AddEncoding gzip .js.gz
  AddEncoding gzip .css.gz
</IfModule>

# Caching headers for assets
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Cache static assets for 1 year (they have hash in filename)
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  
  # Never cache HTML (index.html)
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
